{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "env": {
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    "lib/**",
    "lib-test/**",
    "node_modules/**",
    "coverage/**",
    "tests/fixtures/**"
  ],
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/__tests__/**", "**/tests/**", "**/test/**"],
      "rules": {
        "require-yield": "off"
      }
    }
  ]
}
